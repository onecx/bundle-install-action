{
    "name": "Bundle-install-action",
    "version": "1.0.0",
    "description": "GitHub action to install bundle build tool",
    "type": "module",
    "main": "index.js",
    "scripts": {
        "lint": "eslint .",
        "prepare": "ncc build index.js -o dist --source-map --license licenses.txt",
        "test": "jest",
        "all": "npm run lint && npm run prepare && npm run test"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/onecx/bundle-install-action.git"
    },
    "keywords": [
        "GitHub",
        "Actions",
        "JavaScript",
        "Samo"
    ],
    "author": "Andrej Petras",
    "license": "Apache-2.0",
    "bugs": {
        "url": "https://github.com/onecx/bundle-install-action/issues"
    },
    "homepage": "https://github.com/onecx/bundle-install-action#readme",
    "dependencies": {
        "@actions/core": "^3.0.1",
        "@actions/exec": "^3.0.0",
        "@actions/tool-cache": "^4.0.0"
    },
    "devDependencies": {
        "@eslint/js": "^9.39.1",
        "@vercel/ncc": "^0.38.4",
        "eslint": "^9.39.4",
        "jest": "^30.4.2"
    }
}
